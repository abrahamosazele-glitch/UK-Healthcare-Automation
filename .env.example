# Copy this file to .env and fill in real values. Never commit .env.

# --- Environment ---
# "development" (default) never blocks startup. Set to "production" only
# once SESSION_SECRET_KEY and SESSION_COOKIE_SECURE below are properly
# configured — the app refuses to start with ENVIRONMENT=production and
# either one left at its insecure development default. See
# docs/DEPLOYMENT.md.
ENVIRONMENT=development

# --- AI provider (CV / cover letter generation, job match explanations,
# interview prep, missing-skills analysis) ---
# Leave blank to run entirely on rule-based/fake providers (tests always do,
# regardless of this value). Never commit a real key; never stored anywhere
# but here/the process environment.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_TIMEOUT_SECONDS=60.0
ANTHROPIC_MAX_RETRIES=3
# Approximate published per-million-token pricing, for the cost estimate
# logged alongside every real call — update as pricing changes.
ANTHROPIC_INPUT_COST_PER_MILLION_USD=3.0
ANTHROPIC_OUTPUT_COST_PER_MILLION_USD=15.0

# --- Job ingestion (multi-provider job aggregation) ---
# Reed's public jobseeker API key (https://www.reed.co.uk/developers/jobseeker).
# Leave blank to run without Reed — that provider raises a clear error only
# when it's actually asked to fetch jobs, same pattern as ANTHROPIC_API_KEY.
REED_API_KEY=
# Trac Jobs has no single national search like NHS Jobs does — it's a
# platform individual NHS trusts each run on their own subdomain. Point
# this at one real trust's site (e.g. https://example-trust.trac.jobs)
# before real ingestion; leave blank to keep using the harmless fixture
# placeholder (tests/local verification only). See docs/DEPLOYMENT.md.
TRAC_JOBS_BASE_URL=
# Comma-separated list of providers scheduler.tasks.import_provider_jobs
# actually runs. Indeed/TotalJobs are interface-only stubs today (no
# compliant data source wired up) — omitted from the default list since
# running them would only ever fail.
JOB_INGESTION_PROVIDERS=nhs_jobs,trac_jobs,reed
# Hour of the day (24h, server local time) the daily ingestion refresh runs.
SCHEDULER_JOB_INGESTION_HOUR=6
JOB_INGESTION_CLOSING_SOON_HOURS=48
JOB_INGESTION_HIGH_MATCH_THRESHOLD=80.0
SCHEDULER_SEND_EMAILS_INTERVAL_SECONDS=120
SCHEDULER_DIGEST_CHECK_INTERVAL_SECONDS=3600

# --- Email delivery (real notification emails) ---
# Leave SMTP_HOST blank to run without real email — every notification
# still appears in-app, only the email side is skipped. Tested against
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USERNAME=your full
# @gmail.com address, SMTP_PASSWORD=a 16-character Google Account "App
# Password" (myaccount.google.com/apppasswords — requires 2-Step
# Verification enabled first; your real Gmail password will NOT work here
# and Google will reject the login). See docs/EMAIL_NOTIFICATIONS.md.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=UK Healthcare Job Automation
SMTP_USE_STARTTLS=true

# --- Database ---
# SQLite by default; swap for a Postgres URL in production.
DATABASE_URL=sqlite:///data/jobs.db

# --- Scraper behavior ---
SCRAPE_LOCATIONS=London,Manchester,Birmingham
SCRAPE_KEYWORDS=Healthcare Assistant,Support Worker,Care Assistant,Senior Care Worker
USER_AGENT=Mozilla/5.0 (compatible; UKHealthcareJobBot/1.0)

# --- Candidate profile (used to tailor CVs/cover letters) ---
CANDIDATE_PROFILE_PATH=data/candidate_profile.json

# --- Reporting ---
REPORT_RECIPIENT_EMAIL=
DAILY_REPORT_HOUR=18

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=logs

# --- Browser automation (job_automation.core) ---
BROWSER_HEADLESS=true
BROWSER_SLOW_MO_MS=0
BROWSER_NAVIGATION_TIMEOUT_MS=30000
BROWSER_ACTION_TIMEOUT_MS=10000
BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=800
BROWSER_DOWNLOAD_DIR=data/downloads
BROWSER_SCREENSHOT_DIR=data/screenshots
BROWSER_SESSION_DIR=data/sessions
BROWSER_SESSION_MAX_AGE_HOURS=24
BROWSER_MAX_RETRIES=3
BROWSER_RETRY_BASE_DELAY_SECONDS=1.0
BROWSER_RETRY_MAX_DELAY_SECONDS=30.0
BROWSER_RATE_LIMIT_MIN_DELAY_SECONDS=1.0
BROWSER_RATE_LIMIT_MAX_DELAY_SECONDS=3.0
BROWSER_PROXY_SERVER=
BROWSER_PROXY_USERNAME=
BROWSER_PROXY_PASSWORD=

# --- Scraper framework (job_automation.scrapers.base) ---
SCRAPER_MAX_PAGES=10

# --- Authentication / sessions (job_automation.auth, job_automation.web) ---
# Change this to a real random value (e.g. `python -c "import secrets;
# print(secrets.token_hex(32))"`) before anything but local dev use — it
# signs session cookies, and changing it later logs every user out.
SESSION_SECRET_KEY=dev-insecure-secret-key-change-me
# Set to true once served over HTTPS (not the case for local dev).
SESSION_COOKIE_SECURE=false
SESSION_MAX_AGE_SECONDS=1209600
